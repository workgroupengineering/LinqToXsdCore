  <!-- Movie Tracks -->
  <xs:element name="MovieTracks" type="e:MovieTrack"/>
  <xs:complexType name="MovieTrack">
    <xs:sequence>
      <xs:element ref="e:MovieTrack"/>
    </xs:sequence>
  </xs:complexType>
  <xs:element name="MovieTrack">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="e:TrackName"/>
        <xs:element minOccurs="0" ref="e:TrackEncoding"/>
        <xs:element minOccurs="0" ref="e:StartTime"/>
        <xs:element minOccurs="0" ref="e:TrackDuration"/>
        <xs:element minOccurs="0" ref="e:DataSize"/>
        <xs:element minOccurs="0" ref="e:DataRate"/>
        <xs:element minOccurs="0" ref="e:FPMS"/>
        <xs:element minOccurs="0" ref="e:TrackType"/>
        <xs:element minOccurs="0" ref="e:Chapter"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="TrackName" type="xs:string"/>
  <xs:element name="TrackEncoding" type="xs:string"/>
  <xs:element name="StartTime" type="xs:string"/>
