  <!-- Catalog Sets -->
  <xs:element name="SetList">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:Set"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Set">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="e:SetName"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element ref="e:UniqueID"/>
          <xs:element ref="e:Set"/>
        </xs:choice>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="SetName" type="xs:string"/>
</xs:schema>
