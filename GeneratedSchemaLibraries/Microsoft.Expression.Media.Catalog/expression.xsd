<?xml version="1.0" encoding="UTF-8"?>
<!-- DTD Version 3.1.0 -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="urn:Microsoft.Expression.Media.Catalog" 
  xmlns:e="urn:Microsoft.Expression.Media.Catalog">
  <xs:element name="CatalogType">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="e:Catalog"/>
        <xs:element minOccurs="0" ref="e:CatalogComment"/>
        <xs:element minOccurs="0" ref="e:UserFieldList"/>
        <xs:element minOccurs="0" ref="e:MediaItemList"/>
        <xs:element minOccurs="0" ref="e:SetList"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Catalog">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.Catalog"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.Catalog">
    <xs:attribute name="pathType" use="required"/>
  </xs:attributeGroup>
  <xs:element name="CatalogComment" type="xs:string"/>
  <xs:element name="UserFieldList">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="e:UserFieldDefinition"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="UserFieldDefinition" type="xs:string"/>
  <xs:element name="MediaItemList">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="e:MediaItem"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="MediaItem">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="e:AssetProperties"/>
        <xs:element minOccurs="0" ref="e:MediaProperties"/>
        <xs:element minOccurs="0" ref="e:AnnotationFields"/>
        <xs:element minOccurs="0" ref="e:UserFields"/>
        <xs:element minOccurs="0" ref="e:MetaDataFields"/>
        <xs:element minOccurs="0" ref="e:MovieTracks"/>
        <xs:element minOccurs="0" ref="e:MovieChapterTracks"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <!-- Asset Properties -->
  <xs:element name="AssetProperties">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="e:Filename"/>
        <xs:element ref="e:Filepath"/>
        <xs:element ref="e:UniqueID"/>
        <xs:element ref="e:Label"/>
        <xs:element ref="e:Rating"/>
        <xs:element ref="e:MediaType"/>
        <xs:element ref="e:FileSize"/>
        <xs:element ref="e:Created"/>
        <xs:element ref="e:Modified"/>
        <xs:element ref="e:Added"/>
        <xs:element minOccurs="0" ref="e:Annotated"/>
        <xs:element minOccurs="0" ref="e:ThumbnailSource"/>
        <xs:element minOccurs="0" ref="e:VoiceRecordingSource"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Filename" type="xs:string"/>
  <xs:element name="Filepath" type="xs:string"/>
  <xs:element name="UniqueID" type="xs:string"/>
  <xs:element name="Label" type="xs:string"/>
  <xs:element name="Rating" type="xs:string"/>
  <xs:element name="MediaType" type="xs:string"/>
  <xs:element name="FileSize">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.FileSize"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.FileSize">
    <xs:attribute name="unit" use="required"/>
  </xs:attributeGroup>
  <xs:element name="Created" type="xs:string"/>
  <xs:element name="Modified" type="xs:string"/>
  <xs:element name="Added" type="xs:string"/>
  <xs:element name="Annotated" type="xs:string"/>
  <xs:element name="ThumbnailSource" type="xs:string"/>
  <xs:element name="VoiceRecordingSource" type="xs:string"/>
  <!-- Media Properties -->
  <xs:element name="MediaProperties">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="e:Width"/>
        <xs:element minOccurs="0" ref="e:Height"/>
        <xs:element minOccurs="0" ref="e:Resolution"/>
        <xs:element minOccurs="0" ref="e:Depth"/>
        <xs:element minOccurs="0" ref="e:ViewRotation"/>
        <xs:element minOccurs="0" ref="e:SampleColor"/>
        <xs:element minOccurs="0" ref="e:Pages"/>
        <xs:element minOccurs="0" ref="e:Tracks"/>
        <xs:element minOccurs="0" ref="e:Duration"/>
        <xs:element minOccurs="0" ref="e:Channels"/>
        <xs:element minOccurs="0" ref="e:SampleRate"/>
        <xs:element minOccurs="0" ref="e:SampleSize"/>
        <xs:element minOccurs="0" ref="e:AverageDataRate"/>
        <xs:element minOccurs="0" ref="e:AverageFrameRate"/>
        <xs:element minOccurs="0" ref="e:SpatialQuality"/>
        <xs:element minOccurs="0" ref="e:ColorSpace"/>
        <xs:element minOccurs="0" ref="e:Compression"/>
        <xs:element minOccurs="0" ref="e:PrimaryEncoding"/>
        <xs:element minOccurs="0" ref="e:ColorProfile"/>
        <xs:element minOccurs="0" ref="e:CharacterCount"/>
        <xs:element minOccurs="0" ref="e:ParagraphCount"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Width">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.Width"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.Width">
    <xs:attribute name="unit" use="required"/>
  </xs:attributeGroup>
  <xs:element name="Height">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.Height"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.Height">
    <xs:attribute name="unit" use="required"/>
  </xs:attributeGroup>
  <xs:element name="Resolution">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.Resolution"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.Resolution">
    <xs:attribute name="unit" use="required"/>
  </xs:attributeGroup>
  <xs:element name="Depth">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.Depth"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.Depth">
    <xs:attribute name="unit" use="required"/>
  </xs:attributeGroup>
  <xs:element name="ViewRotation" type="xs:string"/>
  <xs:element name="SampleColor" type="xs:string"/>
  <xs:element name="Pages" type="xs:string"/>
  <xs:element name="Tracks" type="xs:string"/>
  <xs:element name="Duration" type="xs:string"/>
  <xs:element name="Channels" type="xs:string"/>
  <xs:element name="SampleRate" type="xs:string"/>
  <xs:element name="SampleSize" type="xs:string"/>
  <xs:element name="AverageDataRate" type="xs:string"/>
  <xs:element name="AverageFrameRate" type="xs:string"/>
  <xs:element name="SpatialQuality" type="xs:string"/>
  <xs:element name="ColorSpace" type="xs:string"/>
  <xs:element name="Compression" type="xs:string"/>
  <xs:element name="PrimaryEncoding" type="xs:string"/>
  <xs:element name="ColorProfile" type="xs:string"/>
  <xs:element name="CharacterCount" type="xs:string"/>
  <xs:element name="ParagraphCount" type="xs:string"/>
  <!-- Annotation IPTC Fields -->
  <xs:element name="AnnotationFields">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="e:Headline"/>
        <xs:element minOccurs="0" ref="e:Product"/>
        <xs:element minOccurs="0" ref="e:Classification"/>
        <xs:element minOccurs="0" ref="e:IntellectualGenre"/>
        <xs:element minOccurs="0" ref="e:Fixture"/>
        <xs:element minOccurs="0" ref="e:EventDate"/>
        <xs:element minOccurs="0" ref="e:Author"/>
        <xs:element minOccurs="0" ref="e:AuthorTitle"/>
        <xs:element minOccurs="0" ref="e:CreatorAddress"/>
        <xs:element minOccurs="0" ref="e:CreatorCity"/>
        <xs:element minOccurs="0" ref="e:CreatorState"/>
        <xs:element minOccurs="0" ref="e:CreatorPostcode"/>
        <xs:element minOccurs="0" ref="e:CreatorCountry"/>
        <xs:element minOccurs="0" ref="e:CreatorPhone"/>
        <xs:element minOccurs="0" ref="e:CreatorEmail"/>
        <xs:element minOccurs="0" ref="e:CreatorURL"/>
        <xs:element minOccurs="0" ref="e:Credit"/>
        <xs:element minOccurs="0" ref="e:Source"/>
        <xs:element minOccurs="0" ref="e:Copyright"/>
        <xs:element minOccurs="0" ref="e:Transmission"/>
        <xs:element minOccurs="0" ref="e:Rights"/>
        <xs:element minOccurs="0" ref="e:URL"/>
        <xs:element minOccurs="0" ref="e:Location"/>
        <xs:element minOccurs="0" ref="e:City"/>
        <xs:element minOccurs="0" ref="e:State"/>
        <xs:element minOccurs="0" ref="e:Country"/>
        <xs:element minOccurs="0" ref="e:CountryCode"/>
        <xs:element minOccurs="0" ref="e:Instructions"/>
        <xs:element minOccurs="0" ref="e:Status"/>
        <xs:element minOccurs="0" ref="e:Writer"/>
        <xs:element minOccurs="0" ref="e:Caption"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:People"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:Keyword"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:Category"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:Scene"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="e:SubjectReference"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Headline" type="xs:string"/>
  <xs:element name="Product" type="xs:string"/>
  <xs:element name="Classification" type="xs:string"/>
  <xs:element name="IntellectualGenre" type="xs:string"/>
  <xs:element name="Fixture" type="xs:string"/>
  <xs:element name="EventDate" type="xs:string"/>
  <xs:element name="Author" type="xs:string"/>
  <xs:element name="AuthorTitle" type="xs:string"/>
  <xs:element name="CreatorAddress" type="xs:string"/>
  <xs:element name="CreatorCity" type="xs:string"/>
  <xs:element name="CreatorState" type="xs:string"/>
