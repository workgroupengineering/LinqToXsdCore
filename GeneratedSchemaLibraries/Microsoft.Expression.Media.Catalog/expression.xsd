    <xs:attribute name="strID" use="required"/>
  </xs:attributeGroup>
  <xs:element name="NoiseReduction">
    <xs:complexType mixed="true">
      <xs:attributeGroup ref="e:attlist.NoiseReduction"/>
    </xs:complexType>
  </xs:element>
  <xs:attributeGroup name="attlist.NoiseReduction">
    <xs:attribute name="strID" use="required"/>
