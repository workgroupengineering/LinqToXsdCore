        <xs:element minOccurs="0" ref="e:UserField_9"/>
        <xs:element minOccurs="0" ref="e:UserField_10"/>
        <xs:element minOccurs="0" ref="e:UserField_11"/>
        <xs:element minOccurs="0" ref="e:UserField_12"/>
        <xs:element minOccurs="0" ref="e:UserField_13"/>
        <xs:element minOccurs="0" ref="e:UserField_14"/>
        <xs:element minOccurs="0" ref="e:UserField_15"/>
        <xs:element minOccurs="0" ref="e:UserField_16"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="UserField_1" type="xs:string"/>
  <xs:element name="UserField_2" type="xs:string"/>
  <xs:element name="UserField_3" type="xs:string"/>
  <xs:element name="UserField_4" type="xs:string"/>
  <xs:element name="UserField_5" type="xs:string"/>
  <xs:element name="UserField_6" type="xs:string"/>
  <xs:element name="UserField_7" type="xs:string"/>
  <xs:element name="UserField_8" type="xs:string"/>
  <xs:element name="UserField_9" type="xs:string"/>
  <xs:element name="UserField_10" type="xs:string"/>
  <xs:element name="UserField_11" type="xs:string"/>
  <xs:element name="UserField_12" type="xs:string"/>
  <xs:element name="UserField_13" type="xs:string"/>
  <xs:element name="UserField_14" type="xs:string"/>
  <xs:element name="UserField_15" type="xs:string"/>
  <xs:element name="UserField_16" type="xs:string"/>
  <!-- Meta Data -->
  <xs:element name="MetaDataFields">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="e:Maker"/>
        <xs:element minOccurs="0" ref="e:Model"/>
        <xs:element minOccurs="0" ref="e:Software"/>
        <xs:element minOccurs="0" ref="e:Format"/>
        <xs:element minOccurs="0" ref="e:SourceURL"/>
        <xs:element minOccurs="0" ref="e:ExifVersion"/>
        <xs:element minOccurs="0" ref="e:CaptureDate"/>
        <xs:element minOccurs="0" ref="e:ExposureProgram"/>
        <xs:element minOccurs="0" ref="e:ISOSpeedRating"/>
        <xs:element minOccurs="0" ref="e:ExposureBias"/>
        <xs:element minOccurs="0" ref="e:ExposureTime"/>
        <xs:element minOccurs="0" ref="e:Aperture"/>
        <xs:element minOccurs="0" ref="e:SubjectDistance"/>
        <xs:element minOccurs="0" ref="e:MeteringMode"/>
        <xs:element minOccurs="0" ref="e:LightSource"/>
        <xs:element minOccurs="0" ref="e:Flash"/>
        <xs:element minOccurs="0" ref="e:FocalLength"/>
        <xs:element minOccurs="0" ref="e:SensingMethod"/>
        <xs:element minOccurs="0" ref="e:NoiseReduction"/>
        <xs:element minOccurs="0" ref="e:Contrast"/>
        <xs:element minOccurs="0" ref="e:Sharpness"/>
        <xs:element minOccurs="0" ref="e:Saturation"/>
        <xs:element minOccurs="0" ref="e:FocusMode"/>
        <xs:element minOccurs="0" ref="e:DigitalZoom"/>
        <xs:element minOccurs="0" ref="e:Lens"/>
        <xs:element minOccurs="0" ref="e:Latitude"/>
        <xs:element minOccurs="0" ref="e:Longitude"/>
        <xs:element minOccurs="0" ref="e:Altitude"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="Maker" type="xs:string"/>
  <xs:element name="Model" type="xs:string"/>
  <xs:element name="Software" type="xs:string"/>
  <xs:element name="Format" type="xs:string"/>
  <xs:element name="SourceURL" type="xs:string"/>
  <xs:element name="ExifVersion" type="xs:string"/>
  <xs:element name="CaptureDate" type="xs:string"/>
  <xs:element name="ExposureProgram">
