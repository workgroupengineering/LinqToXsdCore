  <xs:element name="Copyright" type="xs:string"/>
  <xs:element name="Transmission" type="xs:string"/>
  <xs:element name="Rights" type="xs:string"/>
  <xs:element name="URL" type="xs:string"/>
  <xs:element name="Location" type="xs:string"/>
  <xs:element name="City" type="xs:string"/>
  <xs:element name="State" type="xs:string"/>
  <xs:element name="Country" type="xs:string"/>
  <xs:element name="CountryCode" type="xs:string"/>
  <xs:element name="Instructions" type="xs:string"/>
  <xs:element name="Status" type="xs:string"/>
  <xs:element name="Writer" type="xs:string"/>
  <xs:element name="Caption" type="xs:string"/>
  <xs:element name="People" type="xs:string"/>
  <xs:element name="Keyword" type="xs:string"/>
  <xs:element name="Category" type="xs:string"/>
  <xs:element name="Scene" type="xs:string"/>
  <xs:element name="SubjectReference" type="xs:string"/>
  <!-- Annotation User Fields -->
  <xs:element name="UserFields">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="e:UserField_1"/>
        <xs:element minOccurs="0" ref="e:UserField_2"/>
        <xs:element minOccurs="0" ref="e:UserField_3"/>
        <xs:element minOccurs="0" ref="e:UserField_4"/>
